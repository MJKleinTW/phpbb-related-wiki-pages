    "version": "0.4.1-alpha",
    "license": "GPL-2.0-only",
    "authors": [
        {
            "name": "MJ Klein",
            "homepage": "https://behringer.world"
        }
    ],
    "require": {
        "php": ">=7.2",
        "composer/installers": "~1.0"
    },
    "extra": {
